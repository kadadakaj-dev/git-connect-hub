{
    "compilerOptions": {
    "types": [
            "vitest/globals",
            "@testing-library/jest-dom",
            "vite/client",
            "vite-plugin-pwa/client"
        ],
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "noEmit": true,
        "noImplicitAny": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "skipLibCheck": true,
        "strict": false,
        "target": "ES2020"
    },
    "include": [
        "src/vite-env.d.ts",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/__tests__/**/*",
        "src/test/**/*"
    ]
}